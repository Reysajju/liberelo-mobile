{
  "name": "liberelo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel --clear",
    "start:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile.ps1",
    "start:mobile": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npx eas-cli@latest build -p android --profile preview",
    "build:apk:local": "powershell -ExecutionPolicy Bypass -File ./scripts/build-apk-local.ps1"
  },
  "dependencies": {
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-document-picker": "~14.0.8",
    "expo-linking": "~8.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
